# Ollama is enabled by default at this local address.
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2

# OpenAI-compatible local servers (include /v1 when required).
VLLM_BASE_URL=
VLLM_MODEL=
VLLM_API_KEY=
SGLANG_BASE_URL=
SGLANG_MODEL=
SGLANG_API_KEY=

# Hugging Face hosted/dedicated OpenAI-compatible endpoint.
HUGGINGFACE_BASE_URL=
HUGGINGFACE_MODEL=
HUGGINGFACE_API_KEY=

# Any other OpenAI-compatible API.
MODEL_API_BASE_URL=
MODEL_API_MODEL=
MODEL_API_KEY=

# Supabase conversation persistence. Keep the service role server-only.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Required for server-only encrypted BYOK credential records. Never expose it.
SUPABASE_SECRET_KEY=

# JSON keyring of 32-byte base64 AES keys. Keep retired versions for decryption
# until every stored credential has been rotated to the active version.
API_KEY_ACTIVE_VERSION=v1
API_KEY_ENCRYPTION_KEYS={"v1":"generate-a-32-byte-base64-secret"}
