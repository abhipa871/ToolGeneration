SGLANG_MODEL=
SGLANG_API_KEY=

# Hugging Face hosted/dedicated OpenAI-compatible endpoint.
HUGGINGFACE_BASE_URL=
HUGGINGFACE_MODEL=
HUGGINGFACE_API_KEY=

# Any other OpenAI-compatible API.
MODEL_API_BASE_URL=
MODEL_API_MODEL=
MODEL_API_KEY=

# Optional future shared persistence. Keep the service role server-only.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
